/* No MCUboot — TF-M boots directly */
#include <samples/cellular/nrf91_no_bootloader_partitions.dtsi>
#include <samples/cellular/nrf91_sram_partitions.dtsi>

/* Console at 1 Mbaud: 115200 (~11.5 KB/s) is fine for live logging but a
 * wall for forensic dumps — the 2 MB flight-recorder tape took ~3 min, and
 * a future 24 MB modem-trace dump would take ~35. The DK's interface MCU
 * bridges 1 M happily (Nordic's own modem-trace UART runs at 1 M through
 * it). make uart matches (BAUD in mk/fw.mk); a default-115200 terminal
 * shows garbage until told otherwise. */
&uart0 {
	current-speed = <1000000>;
};

/* Adafruit LIS3DH accelerometer (the parked wake source — see loc/imu.c):
 *   SDA -> P0.30 (D14), SCL -> P0.31 (D15), VIN -> VDD, INT1 -> P0.19 (A5).
 * SDO/CS untouched: breakout defaults = I2C mode, address 0x18. Absent
 * chip is fine — imu_init() fails and the tracker runs legacy parked mode.
 * anym-mode stays OR (default): imu.c routes the HP filter into the INT
 * engine (CTRL_REG2 poke), so gravity never reaches the comparator; 6D
 * modes were bench-rejected (blind to tumbling between orientation zones).
 */
/* INT1 shares Button 4 (P0.19); disable it so the sensor owns the line. */
&button3 {
	status = "disabled";
};

&arduino_i2c {
	status = "okay";
	lis3dh: lis3dh@18 {
		compatible = "st,lis2dh";
		reg = <0x18>;
		irq-gpios = <&gpio0 19 GPIO_ACTIVE_HIGH>;
		anym-on-int1;
	};
};

/* The DK's on-board 32 MB NOR (GD25WB256, SPI3): flight recorder ring in
 * the first 8 MB; 0x800000..0x2000000 deliberately unallocated — reserved
 * for the Phase-2 obs spill. Layout is hardcoded here on purpose (no GPT):
 * this devicetree IS the partition table. */
&gd25wb256 {
	status = "okay";
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		flight_log: partition@0 {
			label = "flight-log";
			reg = <0x00000000 0x00800000>;
		};
	};
};
