# Copy to .env and edit. .env is git-ignored; CLI (make VAR=..) overrides it.

# MQTT broker the physical nRF9151-DK tracker connects to over LTE.
# Set to your server's public hostname or IP. Default: public test broker.
TRACKER_BROKER_HOST=test.mosquitto.org
TRACKER_BROKER_PORT=1883

# Domain for public HTTPS via Caddy. Leave empty to serve plain HTTP by IP.
CADDY_DOMAIN=

# opencellid.org API token. Only needed for `make update-cells`, which downloads
# the cell-tower CSVs used to place a device that has no GNSS fix. Without a
# cells.db, ingest logs "cell unresolved" and drops the observation.
OPENCELLID_TOKEN=
