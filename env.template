# Copy to .env and edit. .env is git-ignored; CLI (make VAR=..) overrides it.

# CoAP server the physical nRF9151-DK tracker sends to over LTE
# (coap://HOST:PORT/obs, UDP). Set to your server's public hostname or IP.
TRACKER_SERVER_HOST=127.0.0.1
TRACKER_SERVER_PORT=5683

# Domain for public HTTPS via Caddy. Leave empty to serve plain HTTP by IP.
CADDY_DOMAIN=

# opencellid.org API token. Only needed for `make update-cells`, which downloads
# the cell-tower CSVs used to place a device that has no GNSS fix. Without a
# cells.db, the server logs "cell unresolved" and drops the observation.
OPENCELLID_TOKEN=
